<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/background_light"
    android:hapticFeedbackEnabled="true"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/txtvCash"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="R$ 0,00"
        android:textSize="35sp"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="65dp"
        tools:layout_editor_absoluteY="41dp" />

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/materialToolbar"
        android:layout_width="409dp"
        android:layout_height="100dp"
        android:background="@color/white"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="1dp"
        tools:layout_editor_absoluteY="105dp" />

    <TextView
        android:id="@+id/txtvSaldo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Saldo em conta"
        android:textSize="18sp"
        tools:layout_editor_absoluteX="65dp"
        tools:layout_editor_absoluteY="9dp" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="50dp"
        android:layout_height="54dp"
        app:srcCompat="@drawable/baseline_attach_money_24"
        tools:layout_editor_absoluteX="15dp"
        tools:layout_editor_absoluteY="34dp" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Registrar entrada"
        tools:layout_editor_absoluteX="26dp"
        tools:layout_editor_absoluteY="178dp" />

    <TextView
        android:id="@+id/textView4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Registrar saída"
        tools:layout_editor_absoluteX="263dp"
        tools:layout_editor_absoluteY="178dp" />

    <ImageButton
        android:id="@+id/buttonEntrada"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="none"
        app:srcCompat="@drawable/arrow_upward_30dp_000000_fill1_wght400_grad0_opsz24"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="54dp"
        tools:layout_editor_absoluteY="128dp" />

    <ImageButton
        android:id="@+id/buttonSaida"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="none"
        app:srcCompat="@drawable/arrow_downward_30dp_000000_fill1_wght400_grad0_opsz24"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="290dp"
        tools:layout_editor_absoluteY="128dp" />

    <Button
        android:id="@+id/button"
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:background="@color/black"
        android:backgroundTint="@color/black"
        android:shadowColor="@color/black"
        android:text="Visualizar histórico"
        android:textColorLink="#000000"
        app:cornerRadius="20sp"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="5dp"
        tools:layout_editor_absoluteY="667dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/viewTransacoes"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:background="@color/white"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="294dp" />

    <TextView
        android:id="@+id/textView5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Últimas transações"
        android:textSize="25dp"
        tools:layout_editor_absoluteX="179dp"
        tools:layout_editor_absoluteY="231dp" />

</androidx.constraintlayout.widget.ConstraintLayout>